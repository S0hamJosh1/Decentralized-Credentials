generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String            @id
  name               String
  slug               String            @unique
  sector             String
  website            String
  verificationDomain String
  status             String
  description        String
  memberships        Membership[]
  invitations        Invitation[]
  issuers            Issuer[]
  templates          Template[]
  credentials        Credential[]
  credentialEvents   CredentialEvent[]
}

model User {
  id                  String               @id
  fullName            String
  email               String               @unique
  passwordHash        String
  authProvider        String
  googleSubject       String?              @unique
  avatarUrl           String
  emailVerifiedAt     DateTime?
  createdAt           DateTime
  memberships         Membership[]
  invitationsSent     Invitation[]         @relation("InvitationInvitedBy")
  sessions            Session[]
  issuers             Issuer[]
  credentialEvents    CredentialEvent[]
  passwordResetTokens PasswordResetToken[]
}

model Membership {
  id             String       @id
  userId         String
  organizationId String
  role           String
  status         String
  createdAt      DateTime
  updatedAt      DateTime
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, organizationId])
}

model Invitation {
  id              String       @id
  organizationId  String
  code            String       @unique
  name            String
  email           String
  membershipRole  String
  issuerRole      String
  issuerStatus    String
  invitedByUserId String
  status          String
  createdAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  lastSentAt      DateTime?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy       User         @relation("InvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, email, status])
}

model Session {
  id                 String   @id
  token              String   @unique
  userId             String
  activeOrganizationId String
  createdAt          DateTime
  expiresAt          DateTime
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, activeOrganizationId])
}

model Template {
  id             String          @id
  organizationId String
  name           String
  category       String
  validity       String
  summary        String
  status         String
  createdAt      DateTime
  updatedAt      DateTime
  archivedAt     DateTime?
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fields         TemplateField[]

  @@index([organizationId, status])
}

model TemplateField {
  id          String   @id
  templateId  String
  fieldKey    String
  label       String
  type        String
  required    Boolean
  placeholder String
  helpText    String
  fieldOrder  Int
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, fieldOrder])
}

model Issuer {
  id             String       @id
  organizationId String
  userId         String?
  name           String
  role           String
  email          String
  wallet         String
  status         String
  createdAt      DateTime
  updatedAt      DateTime
  approvedAt     DateTime?
  walletVerifiedAt DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  credentials    Credential[]

  @@index([organizationId, email])
}

model Credential {
  id               String                 @id
  organizationId   String
  verificationCode String                 @unique
  verificationUrl  String
  credentialHash   String
  anchorStatus     String
  chainId          String
  network          String
  contractAddress  String
  txHash           String
  blockNumber      String
  anchoredAt       String
  revokeTxHash     String
  revokeBlockNumber String
  revokedOnChainAt String
  recipientName    String
  recipientEmail   String
  recipientWallet  String
  templateId       String
  templateName     String
  issuerId         String
  issuerWallet     String
  issuedBy         String
  issuedAt         String
  status           String
  cohort           String
  summary          String
  revokedAt        String
  revocationReason String
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  issuer           Issuer                 @relation(fields: [issuerId], references: [id], onDelete: Restrict)
  fieldValues      CredentialFieldValue[]
  events           CredentialEvent[]

  @@index([organizationId, status])
}

model CredentialFieldValue {
  id          String     @id
  credentialId String
  fieldId     String
  fieldKey    String
  label       String
  type        String
  value       String
  fieldOrder  Int
  credential  Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId, fieldOrder])
}

model CredentialEvent {
  id             String       @id
  credentialId   String?
  organizationId String
  actorUserId    String?
  type           String
  createdAt      DateTime
  details        Json
  credential     Credential?  @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser      User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([credentialId, createdAt])
}

model PasswordResetToken {
  id         String    @id
  userId     String
  tokenHash  String    @unique
  createdAt  DateTime
  expiresAt  DateTime
  usedAt     DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
